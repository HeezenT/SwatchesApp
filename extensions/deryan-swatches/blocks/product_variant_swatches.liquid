{%- liquid
  assign product_resource = closest.product
  assign configured_product = block.settings.product

  if product_resource == blank
    assign product_resource = product
  endif

  if configured_product != blank and configured_product.id != blank
    assign product_resource = configured_product
  endif

  assign current_variant = product_resource.selected_or_first_available_variant
  assign group_data = product_resource.metafields.deryan_swatches.group.value
  assign app_appearance = shop.metafields.deryan_swatches.appearance.value
  assign block_uid = block.id | default: product_resource.id
  assign accent_color = app_appearance.accentColor | default: block.settings.accent_color
  assign border_color = app_appearance.borderColor | default: block.settings.border_color
  assign active_background_color = app_appearance.activeBackgroundColor | default: block.settings.active_background_color
  assign inactive_background_color = app_appearance.inactiveBackgroundColor | default: block.settings.inactive_background_color
  assign text_color = app_appearance.textColor | default: block.settings.text_color
  assign active_text_color = app_appearance.activeTextColor | default: block.settings.active_text_color
  assign inactive_text_color = app_appearance.inactiveTextColor | default: block.settings.inactive_text_color
  assign block_height = app_appearance.blockHeight | default: block.settings.block_height
  assign corner_radius = app_appearance.cornerRadius | default: block.settings.corner_radius
  assign header_font_size = app_appearance.headerFontSize | default: block.settings.header_font_size
  assign value_font_size = app_appearance.valueFontSize | default: block.settings.value_font_size
  assign button_font_size = app_appearance.buttonFontSize | default: block.settings.button_font_size
  assign header_font_weight = app_appearance.headerFontWeight | default: block.settings.header_font_weight
  assign value_font_weight = app_appearance.valueFontWeight | default: block.settings.value_font_weight
  assign button_font_weight = app_appearance.buttonFontWeight | default: block.settings.button_font_weight
-%}

{%- unless product_resource == blank -%}
  {{ 'deryan-swatches.css' | asset_url | stylesheet_tag }}

  <deryan-variant-swatches
    class="deryan-swatches"
    data-product-id="{{ product_resource.id }}"
    data-product-url="{{ product_resource.url }}"
    data-section-id="{{ section.id }}"
    data-money-format="{{ shop.money_format | strip_html | escape }}"
    data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
    data-hide-native-picker="{{ block.settings.hide_native_variant_picker }}"
    style="
      --deryan-swatches-accent: {{ accent_color }};
      --deryan-swatches-border: {{ border_color }};
      --deryan-swatches-active-bg: {{ active_background_color }};
      --deryan-swatches-inactive-bg: {{ inactive_background_color }};
      --deryan-swatches-text: {{ text_color }};
      --deryan-swatches-active-text: {{ active_text_color }};
      --deryan-swatches-inactive-text: {{ inactive_text_color }};
      --deryan-swatches-radius: {{ corner_radius }}px;
      --deryan-swatches-min-height: {{ block_height }}px;
      --deryan-swatches-header-size: {{ header_font_size }}px;
      --deryan-swatches-value-size: {{ value_font_size }}px;
      --deryan-swatches-button-size: {{ button_font_size }}px;
      --deryan-swatches-header-weight: {{ header_font_weight }};
      --deryan-swatches-value-weight: {{ value_font_weight }};
      --deryan-swatches-button-weight: {{ button_font_weight }};
    "
    {{ block.shopify_attributes }}
  >
    {%- if group_data and group_data.products.size > 1 -%}
      <fieldset
        class="deryan-swatches__option deryan-swatches__option--color"
        data-product-group
        data-static-helper="{{ group_data.helperText | escape }}"
        data-tooltip-text="{{ group_data.tooltipText | escape }}"
      >
        <legend class="deryan-swatches__legend">
          <span class="deryan-swatches__option-heading">
            <span class="deryan-swatches__option-name">{{ group_data.optionName | default: 'Kleur' | escape }}</span>
            {%- if group_data.tooltipText != blank -%}
              <button class="deryan-swatches__info" type="button" aria-label="Meer informatie">
                i
                <span class="deryan-swatches__tooltip" role="tooltip">{{ group_data.tooltipText | escape }}</span>
              </button>
            {%- endif -%}
          </span>
          <span class="deryan-swatches__selected-value" data-selected-value>
            {%- if group_data.helperText != blank -%}
              {{ group_data.helperText | escape }}
            {%- else -%}
              {%- for grouped_product in group_data.products -%}
                {%- if grouped_product.handle == product_resource.handle -%}
                  {{ grouped_product.value | escape }}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </span>
        </legend>

        <div class="deryan-swatches__grid">
          {%- for grouped_product in group_data.products -%}
            {%- liquid
              assign grouped_value = grouped_product.value | default: grouped_product.title
              assign grouped_color = grouped_product.color | default: '#d8d8d8'
              assign grouped_url = grouped_product.url
              assign is_current_product = false

              if grouped_url == blank
                assign grouped_url = grouped_product.handle | prepend: '/products/'
              endif

              if grouped_product.handle == product_resource.handle
                assign is_current_product = true
              endif
            -%}

            <a
              class="deryan-swatches__button{% if is_current_product %} deryan-swatches__button--active{% endif %}"
              href="{{ grouped_url }}"
              aria-current="{% if is_current_product %}true{% else %}false{% endif %}"
              aria-label="{{ grouped_value | escape }}"
            >
              <span
                class="deryan-swatches__swatch"
                style="
                  --deryan-swatch-background: {{ grouped_color }};
                  --deryan-swatch-focal-point: center;
                  --deryan-check-color: #ffffff;
                "
                aria-hidden="true"
              ></span>
              <span class="deryan-swatches__sr-only">{{ grouped_value | escape }}</span>
            </a>
          {%- endfor -%}
        </div>
      </fieldset>
    {%- elsif product_resource.has_only_default_variant == false -%}
      {%- for product_option in product_resource.options_with_values -%}
      {%- liquid
        assign option_handle = product_option.name | handleize
        assign swatch_count = product_option.values | map: 'swatch' | compact | size
        assign is_color_option = false

        if option_handle contains 'kleur' or option_handle contains 'color' or option_handle contains 'colour'
          assign is_color_option = true
        endif

        if swatch_count > 0
          assign is_color_option = true
        endif
      -%}

      <fieldset
        class="deryan-swatches__option{% if is_color_option %} deryan-swatches__option--color{% endif %}"
        data-option-index="{{ product_option.position | minus: 1 }}"
        data-option-name="{{ product_option.name | escape }}"
      >
        <legend class="deryan-swatches__legend">
          <span class="deryan-swatches__option-heading">
            <span class="deryan-swatches__option-name">{{ product_option.name | escape }}</span>
          </span>
          <span class="deryan-swatches__selected-value" data-selected-value>{{ product_option.selected_value }}</span>
        </legend>

        <div class="deryan-swatches__grid">
          {%- for product_option_value in product_option.values -%}
            {%- liquid
              assign input_id = 'DeryanSwatch-' | append: block_uid | append: '-' | append: product_option.position | append: '-' | append: forloop.index0
              assign value_name = product_option_value.name | default: product_option_value
              assign value_handle = value_name | handleize
              assign swatch_background = '#d8d8d8'
              assign swatch_focal_point = ''
              assign swatch_check_color = '#ffffff'
              assign variant_helper_text = product_option_value.variant.metafields.deryan_swatches.helper_text.value

              if product_option_value.swatch.image
                assign swatch_image_url = product_option_value.swatch.image | image_url: width: 120
                assign swatch_background = 'url(' | append: swatch_image_url | append: ')'
                assign swatch_focal_point = product_option_value.swatch.image.presentation.focal_point
              elsif product_option_value.swatch.color
                assign swatch_background = 'rgb(' | append: product_option_value.swatch.color.rgb | append: ')'
              elsif is_color_option
                case value_handle
                  when 'zwart', 'black'
                    assign swatch_background = '#111111'
                  when 'wit', 'white'
                    assign swatch_background = '#ffffff'
                  when 'creme', 'cream', 'beige', 'zand', 'sand', 'taupe'
                    assign swatch_background = '#e8ddcf'
                  when 'grijs', 'gray', 'grey', 'lichtgrijs', 'light-grey', 'light-gray'
                    assign swatch_background = '#c9c9c9'
                  when 'donkergrijs', 'dark-grey', 'dark-gray'
                    assign swatch_background = '#4b4b4b'
                  when 'blauw', 'blue', 'navy', 'donkerblauw'
                    assign swatch_background = '#2f5f9f'
                  when 'groen', 'green'
                    assign swatch_background = '#4f7d55'
                  when 'roze', 'pink'
                    assign swatch_background = '#e8a6b8'
                  when 'rood', 'red'
                    assign swatch_background = '#c83d35'
                  when 'bruin', 'brown'
                    assign swatch_background = '#7a523b'
                endcase
              endif

              if value_handle == 'wit' or value_handle == 'white' or value_handle == 'creme' or value_handle == 'cream' or value_handle == 'beige' or value_handle == 'zand' or value_handle == 'sand'
                assign swatch_check_color = '#111111'
              endif
            -%}

            <input
              class="deryan-swatches__input"
              id="{{ input_id }}"
              type="radio"
              name="DeryanOption-{{ block_uid }}-{{ product_option.position }}"
              value="{{ product_option_value | escape }}"
              data-option-input
              data-option-index="{{ product_option.position | minus: 1 }}"
              data-option-value-id="{{ product_option_value.id }}"
              data-variant-id="{{ product_option_value.variant.id }}"
              data-helper-text="{{ variant_helper_text | escape }}"
              data-option-available="{{ product_option_value.available }}"
              aria-label="{{ product_option_value.name | escape }}{% unless product_option_value.available %} - {{ 'deryan_swatches.sold_out' | t }}{% endunless %}"
              {% unless product_option_value.available %}aria-disabled="true"{% endunless %}
              {% if product_option_value.selected %}checked{% endif %}
            >

            <label class="deryan-swatches__button" for="{{ input_id }}">
              {%- if is_color_option -%}
                <span
                  class="deryan-swatches__swatch"
                  style="
                    --deryan-swatch-background: {{ swatch_background }};
                    --deryan-swatch-focal-point: {{ swatch_focal_point | default: 'center' }};
                    --deryan-check-color: {{ swatch_check_color }};
                  "
                  aria-hidden="true"
                ></span>
                <span class="deryan-swatches__sr-only">{{ product_option_value | escape }}</span>
              {%- else -%}
                <span class="deryan-swatches__text">{{ product_option_value | escape }}</span>
              {%- endif -%}

              <span class="deryan-swatches__strike" aria-hidden="true"></span>
            </label>
          {%- endfor -%}
        </div>
      </fieldset>
      {%- endfor -%}

      <script type="application/json" data-product-json>
        {
          "productId": {{ product_resource.id | json }},
          "productUrl": {{ product_resource.url | json }},
          "selectedVariantId": {{ current_variant.id | json }},
          "variants": {{ product_resource.variants | json }}
        }
      </script>

      <script type="application/json" data-helper-map>{{ block.settings.helper_text_map | json }}</script>
      <script type="application/json" data-tooltip-map>{{ block.settings.tooltip_text_map | json }}</script>
    {%- endif -%}
  </deryan-variant-swatches>

  <script src="{{ 'deryan-swatches.js' | asset_url }}" defer></script>
{%- endunless -%}

{% schema %}
{
  "name": "Deryan variant swatches",
  "target": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "checkbox",
      "id": "hide_native_variant_picker",
      "label": "Hide theme variant picker",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Selected border color",
      "default": "#ff7a2f"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Inactive border color",
      "default": "#d5dae2"
    },
    {
      "type": "color",
      "id": "active_background_color",
      "label": "Selected background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "inactive_background_color",
      "label": "Inactive background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Header text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "active_text_color",
      "label": "Selected button text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "inactive_text_color",
      "label": "Inactive button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "block_height",
      "label": "Block height",
      "min": 72,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 108
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 4,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "header_font_size",
      "label": "Header font size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "value_font_size",
      "label": "Right value font size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 13,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "header_font_weight",
      "label": "Header font weight",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 800
    },
    {
      "type": "range",
      "id": "value_font_weight",
      "label": "Right value font weight",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 800
    },
    {
      "type": "range",
      "id": "button_font_weight",
      "label": "Button font weight",
      "min": 400,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "textarea",
      "id": "helper_text_map",
      "label": "Helper text map",
      "info": "One per line: Option name|Option value|Right-side helper text. Use * for any value.",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "tooltip_text_map",
      "label": "Tooltip text map",
      "info": "One per line: Option name|Tooltip text.",
      "default": ""
    }
  ]
}
{% endschema %}
